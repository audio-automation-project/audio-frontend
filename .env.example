# Copy to .env.local (Vite loads it automatically) or set in the shell.
# Vite exposes only variables prefixed with VITE_.

VITE_CORE_API_URL=http://localhost:8088
# Production / Railway: point at the deployed bot (HTTPS), and add that origin to the bot's CORS_ALLOWED_ORIGINS.
# VITE_CORE_API_URL=https://your-audio-bot.up.railway.app
VITE_SILENCE_API_URL=http://localhost:8090

# Optional: poll async FFmpeg jobs exposed by the core API (PostgreSQL-backed).
# POST {VITE_CORE_API_URL}/api/v1/jobs/audio/concatenate  →  202 + job id (and X-Correlation-Id echoed)
# GET  {VITE_CORE_API_URL}/api/v1/jobs/{jobId}  → status SUCCEEDED | FAILED | …
